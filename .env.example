# Spring datasource (application.yml picks these up)
DB_URL=jdbc:mariadb://localhost:3306/property_search
DB_USER=admin
DB_PASSWORD=admin123

# Docker MariaDB (optional; useful if you externalize compose vars later)
MARIADB_ROOT_PASSWORD=rootpassword
MARIADB_DATABASE=property_search
MARIADB_USER=admin
MARIADB_PASSWORD=admin123
LUCENE_INDEX_PATH=<where you want to keep the index file in you machine>
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX_NAME=property-evaluation-search
